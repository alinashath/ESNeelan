EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public web origin (no trailing slash) — canonical URLs, Open Graph, and share links.
# Example: https://app.esneelan.com
# EXPO_PUBLIC_SITE_URL=

# Optional absolute URL to a 1200×630 (or similar) default social preview image.
# EXPO_PUBLIC_DEFAULT_OG_IMAGE_URL=

# Optional: database password for CLI migrations (`supabase db push`). From Dashboard → Settings → Database.
# SUPABASE_DB_PASSWORD=
EXPO_PUBLIC_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1
